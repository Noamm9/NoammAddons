{
  "schemaVersion": 1,
  "id": "noammaddons",
  "version": "${version}",
  "name": "NoammAddons",
  //#if CHEAT
  "description": "1.21.11 port of the greatest skyblock mod ever made! Version: Cheat",
  //#else
  //$"description": "1.21.11 port of the greatest skyblock mod ever made! Version: Legit",
  //#endif
  "authors": [
    "Noamm"
  ],
  "contact": {
    "homepage": "https://github.com/Noamm9",
    "sources": "https://github.com/Noamm9/NoammAddons",
    "issues": "https://github.com/Noamm9/NoammAddons/issues"
  },
  "license": "CC0-1.0",
  "icon": "assets/noammaddons/icon.png",
  "environment": "*",
  "entrypoints": {
    "client": [
      {
        "value": "com.github.noamm9.NoammAddons",
        "adapter": "kotlin"
      }
    ]
  },
  "mixins": [
    "noammaddons.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.17.3",
    "minecraft": "~1.21.11",
    "java": ">=21",
    "fabric-api": "*",
    "fabric-language-kotlin": "*"
  },
  "custom": {
    "modmenu": {
      "links": {
        "Discord": "https://discord.com/invite/pj9mQGxMxB"
      }
    }
  }
}